        },
        "parameters": [
          {
            "name": "nsType",
            "description": "\"mnt\", \"net\", \"uts\", \"user\"",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "nsInode",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "referencePid",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          }
        ],
        "tags": [
          "BeemonService"
        ]
      }
    },
